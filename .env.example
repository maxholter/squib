# PayTrack runs locally with zero configuration by default.
# Everything below is OPTIONAL.

# Where the local SQLite database file lives. Defaults to ./data/paytrack.db
# DATABASE_PATH=./data/paytrack.db

# Secret used to sign session cookies. A stable default is used in development,
# but you SHOULD set a long random value in production.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# SESSION_SECRET=change-me-to-a-long-random-string

# ---------------------------------------------------------------------------
# Future Supabase upgrade path (not used by the local-first build).
# See UPGRADE_TO_SUPABASE.md for details.
# NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
